POSTGRES_DB_HOST=localhost
POSTGRES_DB_PORT=5432
POSTGRES_DB=lakeagent_db
POSTGRES_DB_USER=lakeagent
POSTGRES_DB_PASSWORD=lakeagent123

DATALAKE_DIR=/data/Data-Lake

# Main LLM and embeddings through local 9Router.
OPENAI_API_KEY=
OPENAI_MODEL_NAME=openrouter/openai/gpt-4o-mini
OPENAI_EMBEDDING_MODEL_NAME=openrouter/openai/text-embedding-3-small
OPENAI_BASE_URL=http://localhost:20128/v1
OPENAI_EMBEDDING_DIMENSIONS=1536

OCR_MODEL_NAME=
OCR_BASE_URL=
OCR_REQUEST_TIMEOUT_SECONDS=120

# Direct OpenRouter settings for audio ASR.
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# Audio transcription for audio files and video audio tracks.
# Leave ASR_API_KEY/ASR_BASE_URL blank to use OPENROUTER_API_KEY/OPENROUTER_BASE_URL.
# Set ASR_API_KEY/ASR_BASE_URL only when ASR should use a different OpenAI-compatible endpoint.
ASR_API_KEY=
ASR_BASE_URL=
ASR_MODEL_NAME=microsoft/mai-transcribe-1.5
ASR_FALLBACK_MODEL_NAME=mistralai/voxtral-mini-transcribe
ASR_MAX_CHUNK_SECONDS=600
ASR_CHUNK_OVERLAP_SECONDS=8

# Optional video VLM frame captioning. VIDEO_VL_MODEL_NAME falls back to VL_MODEL_NAME
# then OPENAI_MODEL_NAME when blank.
VIDEO_VL_API_KEY=
VIDEO_VL_BASE_URL=http://localhost:20128/v1
VIDEO_MAX_FRAMES=8
VIDEO_FRAME_LONG_EDGE=768
VIDEO_VL_MODEL_NAME=openrouter/openai/gpt-4o-mini

# EPUB embedded image captioning. High thinking is selected in 9Router UI;
# do not include "(high)" in the model id.
EPUB_VL_API_KEY=
EPUB_VL_BASE_URL=http://localhost:20128/v1
EPUB_VL_MODEL_NAME=openrouter/qwen/qwen3-vl-32b-instruct
EPUB_VL_LONG_EDGE=768
EPUB_MAX_IMAGES_PER_FILE=20
EPUB_ENRICH_SECTION_COUNT=12
